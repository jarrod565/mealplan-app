# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Spoonacular (recipe data)
VITE_SPOONACULAR_API_KEY=your-spoonacular-api-key

# Stripe (publishable key — safe to expose in frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Airtable OAuth (CB_12) — client ID is safe to expose, it only builds the
# authorize URL. Register the redirect URI as:
#   https://your-domain/settings/connections/airtable/callback
VITE_AIRTABLE_CLIENT_ID=your-airtable-oauth-client-id

# Pinterest OAuth (CB_09) — client ID is safe to expose, it only builds the
# authorize URL. Register the redirect URI as:
#   https://your-domain/settings/connections/pinterest/callback
VITE_PINTEREST_CLIENT_ID=1586451

# ── Supabase Edge Functions only (never expose to frontend) ──
# Set these in the Supabase dashboard under Project Settings > Edge Functions
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PREMIUM_PRICE_ID=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# SUPABASE_SERVICE_ROLE_KEY=...
# AIRTABLE_CLIENT_ID=your-airtable-oauth-client-id
# AIRTABLE_CLIENT_SECRET=your-airtable-oauth-client-secret
# PINTEREST_CLIENT_ID=your-pinterest-oauth-client-id
# PINTEREST_CLIENT_SECRET=your-pinterest-oauth-client-secret
